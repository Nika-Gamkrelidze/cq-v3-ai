# PHP sends this in the X-API-Key header when posting calls
SERVICE_API_KEY=change-me-to-a-long-random-string

# Protects the admin panel (sent as the X-Admin-Token header)
ADMIN_TOKEN=change-me-to-a-long-random-string

# Super-admin login for the admin panel (username + password)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=change-me

# For running host-side tools; the api container overrides this to reach the 'db' service
DATABASE_URL=postgresql://cq:cq@localhost:5432/cq

# Integration keys. These are bootstrap/fallback values — the admin panel can
# override them at runtime (stored in the DB app_settings table).
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
S3_ENDPOINT_URL=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=

# Embeddings (provider-swappable via the admin panel). Default: self-hosted BGE-M3
# via a Text-Embeddings-Inference (TEI) container — multilingual, no external key.
# To use OpenAI instead: EMBEDDING_PROVIDER=openai, EMBEDDING_MODEL=text-embedding-3-large,
# EMBEDDING_DIM=3072, EMBEDDING_API_KEY=sk-... (dim change requires re-embedding the KB).
EMBEDDING_PROVIDER=tei
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# EMBEDDING_BASE_URL defaults to http://embeddings:80 (set by docker-compose)

# Secret for signing tenant-user session tokens (HMAC)
JWT_SECRET=change-me-to-a-long-random-string
