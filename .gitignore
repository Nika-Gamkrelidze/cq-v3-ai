.venv/
__pycache__/
*.pyc
# Secrets & env — never commit real values (.env.example is the placeholder template)
.env
*.env
!.env.example
# Keys / certs
*.pem
*.key
*.p12
*.pfx
# TLS certs copied from Let's Encrypt into the repo dir for the nginx bind-mount
deploy/certs/
# ACME HTTP-01 challenge files (transient, written under the served webroot)
frontend/public/.well-known/
id_rsa
id_ed25519
*_rsa
*_ed25519
# Local-only compose override (host port bindings, dev mounts)
docker-compose.override.yml
# Local-only operational notes (server access, VPN, credential pointers) — never commit
*.local.md
# Data volumes / build output / logs
pgdata/
node_modules/
.next/
*.log
.DS_Store
